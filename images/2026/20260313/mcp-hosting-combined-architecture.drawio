                <mxCell id="callout-title" value="&lt;font style=&quot;font-size:13px&quot;&gt;&lt;b&gt;💡 Key Insight: Complementary Pattern&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="720" y="725" width="530" height="25" as="geometry"/>
                </mxCell>
                <mxCell id="callout-text" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;APIM + MCP Gateway are not interchangeable — use them together:&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;APIM&lt;/b&gt; = North-South: OAuth validation, rate limits, monitoring, credential brokering&lt;br&gt;• &lt;b&gt;MCP Gateway&lt;/b&gt; = East-West: Session-aware routing, adapter lifecycle, stdio bridging&lt;br&gt;• &lt;b&gt;Alt Compute&lt;/b&gt; (Container Apps, Functions) = Build custom MCP servers with per-user auth&lt;br&gt;• &lt;b&gt;API Center&lt;/b&gt; = Discover and govern which MCP servers developers can use&lt;br&gt;&lt;br&gt;&lt;b&gt;GitHub MCP Server&lt;/b&gt;: Keep as direct connection — it uses GitHub OAuth (not Entra ID),&lt;br&gt;is already cloud-hosted, and requires no containerization or proxying.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="735" y="755" width="500" height="140" as="geometry"/>
                </mxCell>
